from time import sleep
from rich import print
from rich.panel import Panel

def line(size = 30):
    return '-' * size


def header(text):
    panel = Panel(f'{text.center(25)}', width=30)
    print(panel)


def error(msg):
    print(f'[red]ERROR! {msg}[/]')
    sleep(1.5)


def menu():
    header('Shop')
    print('1 :books: Show Registered Customers')
    print('2 :heavy_plus_sign:  Register New Customer')
    print('3 :heavy_dollar_sign: Launch Billing')
    print('4 :heavy_check_mark:  Annual Revenue')
    print('5 :heavy_large_circle:  Leave System')
    print(line())


def create_and_read_doc(name):
    with open(name, 'a'):
        pass
    with open(name, 'r', encoding='utf-8') as p:
        content = p.read()
        print(content)


def register_new_customer():
    name = input('Name: ').strip().lower()
    if not name:
        error('The name cannot be empty')
        print("[red]Let's start from the beginning...[/]")
        return
    if not name.replace(' ', '').isalpha():
        error('Must contain only letters!')
        print("[red]Let's start from the beginning...[/]")
        return
    try:
        price = int(input('Price: '))
        if price <= 0:
            error('The value must be a number greater than zero!')
            print("[red]Let's start from the beginning...[/]")
            return
    except ValueError:
        error('The value must be a number')
        print("[red]Let's start from the beginning...[/]")
        return
    service = input('Service: ').strip().lower()
    if not service:
        error('The service cannot be empty!')
        print("[red]Let's start from the beginning...[/]")
        return
    with open('customers.txt', 'a', encoding='utf-8') as p:
        p.write(f'{name:<20} {service:^10} R${price:>2}\n')
    print('Registration Successful!')


def revenue():
    try:
        sell = float(input('Enter the selling price: '))
        if sell <= 0:
            error('The value must be a number greater than zero!')
            print("[red]Let's start from the beginning...[/]")
            return
    except ValueError:
        error('The value must be a number!')
        print("[red]Let's start from the beginning...[/]")
        return
    with open('revenue.txt', 'a', encoding='utf-8') as f:
        f.write(f'R${sell:<30}\n')
    print('Value registration completed successfully!')


def system():
    while True:
        menu()
        try:
            choice = int(input('Enter your choice: '))
            if choice == 1:
                header("Registered Customers")
                create_and_read_doc('customers.txt')
                sleep(1)
            elif choice == 2:
                header("New Registration")
                register_new_customer()
                sleep(1)
            elif choice == 3:
                header("Revenue Registration")
                revenue()
                sleep(1)
            elif choice == 4:
                header("Total Revenue")
                create_and_read_doc('revenue.txt')
                sleep(1)
            elif choice == 5:
                header("Exiting the system... See you later!")
                sleep(1)
                break
            else:
                error('Please enter a number from 1 to 5 only!')
                sleep(1.5)
        except ValueError:
            error('Please enter a number from 1 to 5 only!')
            sleep(1.5)
        except KeyboardInterrupt:
            print()
            header('Exiting the system... See you later!')
            sleep(1)
            break

system()
